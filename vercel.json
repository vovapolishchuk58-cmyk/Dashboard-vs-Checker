{
  "version": 2,
  "builds": [
    {
      "src": "dashboardgimini.py",
      "use": "@vercel/python"
    },
    {
      "src": "api/cron.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/cron",
      "dest": "api/cron.py"
    },
    {
      "src": "/(.*)",
      "dest": "dashboardgimini.py"
    }
  ],
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "0 5 * * *"
    }
  ]
}
