{
  "version": 2,
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "0 5 * * *"
    }
  ],
  "functions": {
    "api/cron.py": {
      "maxDuration": 60
    },
    "api/dashboardgimini.py": {
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/api/cron",
      "dest": "api/cron.py"
    },
    {
      "src": "/(.*)",
      "dest": "api/dashboardgimini.py"
    }
  ]
}
